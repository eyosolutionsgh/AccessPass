{
  "name": "vms",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Visitor Management System — on-facility, invitation-code/QR check-in",
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:server": "pnpm --filter @vms/server dev",
    "dev:web": "pnpm --filter @vms/web dev",
    "build": "pnpm -r build",
    "vercel-build": "pnpm --filter @vms/web build && pnpm --filter @vms/server build:serverless",
    "check": "pnpm -r check",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "pnpm -r test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^9.18.0",
    "@types/node": "^24.7.0",
    "concurrently": "^9.1.2",
    "dotenv": "^17.2.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "pg": "^8.13.1",
    "prettier": "^3.6.2",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.20.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "electron"
    ]
  }
}
