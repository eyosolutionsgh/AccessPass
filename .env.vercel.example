# ── VMS on Vercel (demo deployment) ─────────────────────────────────────────────────────────────
# Set these in the Vercel project's Environment Variables. This is the DEMO deployment only; the
# on-prem reference stack lives in deploy/ and uses none of the managed services below.
#
# NOTE: Vercel bakes env vars at BUILD time — after changing one you must trigger a NEW deployment
# (a fresh deployment id), not an empty commit, for it to take effect.

# ── Database — Neon Postgres ─────────────────────────────────────────────────────────────────────
# Use the POOLED (-pooler) Neon connection string here (functions open a connection per cold start).
# Run migrations + seed from your machine against the DIRECT (non-pooled) string:
#   DATABASE_URL=<neon-direct-url> pnpm db:migrate && pnpm --filter @vms/server seed
# Ensure the pgvector extension is available (Neon: CREATE EXTENSION IF NOT EXISTS vector).
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/vms?sslmode=require

# ── Auth / crypto ────────────────────────────────────────────────────────────────────────────────
# Same-origin single project: point all three at the project's public URL.
BETTER_AUTH_SECRET=change-me-32+chars
BETTER_AUTH_URL=https://YOUR-PROJECT.vercel.app
APP_URL=https://YOUR-PROJECT.vercel.app
WEB_ORIGIN=https://YOUR-PROJECT.vercel.app
QR_TOKEN_SECRET=change-me-16+chars
FIELD_ENCRYPTION_KEY=change-me-16+chars

# ── Redis — Upstash (rate limiter + /ready probe) ───────────────────────────────────────────────
# Use the Upstash Redis TCP/TLS endpoint (rediss://). BullMQ does NOT run on Vercel.
REDIS_URL=rediss://default:PASSWORD@YOUR-DB.upstash.io:6379

# ── Scheduled sweeps — Upstash QStash (replaces the BullMQ repeatable jobs) ──────────────────────
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
API_PUBLIC_URL=https://YOUR-PROJECT.vercel.app

# ── Object storage — Cloudflare R2 (S3-compatible; selfie/ID capture) ───────────────────────────
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=vms-documents

# ── Email — MailerSend HTTP API ─────────────────────────────────────────────────────────────────
MAILERSEND_API_TOKEN=
MAILERSEND_FROM_EMAIL=vms@3dt.com.gh
MAILERSEND_FROM_NAME=vms

# ── Realtime — Ably (server publishes contentless "refetch" pokes) ──────────────────────────────
REALTIME_PROVIDER=ably
ABLY_API_KEY=

# Optional: reseed the admin on boot (idempotent — won't reset an existing admin's password).
SEED_ON_START=true

# ── Build-time (must be present when Vercel runs the web build) ─────────────────────────────────
# Same-origin ⇒ leave VITE_API_URL empty. Select the Ably client transport for the SPA:
VITE_REALTIME_PROVIDER=ably
# VITE_API_URL=
