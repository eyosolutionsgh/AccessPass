# ──────────────────────────────────────────────────────────────────────────
# VMS environment — copy to .env and fill in. NEVER commit a real .env.
# On-prem deployment: all services are self-hosted (no cloud dependencies).
# ──────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# Server
PORT=4000
# Internal origin staff browsers and kiosks reach the API on (used for QR check-in URLs)
APP_URL=http://localhost:4000
# Web origin allowed by CORS
WEB_ORIGIN=http://localhost:5173
# Web origins baked into the Vite client bundle for staff URL guidance in /help.
VITE_INTERNAL_WEB_ORIGIN=https://vms.example
VITE_LOCAL_WEB_ORIGIN=http://localhost:5173

# Auth (better-auth). Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-please-generate-a-32-byte-secret
BETTER_AUTH_URL=http://localhost:4000

# Secret used to sign/HMAC invitation QR tokens (separate from auth secret).
QR_TOKEN_SECRET=change-me-another-32-byte-secret
# Secret for AES-256-GCM encryption of sensitive identifiers (ID/passport).
FIELD_ENCRYPTION_KEY=change-me-32-byte-key-for-aes-256-gcm

# PostgreSQL (self-hosted) — host port 5544 (see docker-compose.yml)
DATABASE_URL=postgresql://vms:vms@localhost:5544/vms

# Redis (self-hosted) — cache, rate-limit store, BullMQ — host port 6390
REDIS_URL=redis://localhost:6390

# Object storage — MinIO (S3-compatible, on-prem) — host port 9100 (console 9101)
S3_ENDPOINT=http://localhost:9100
S3_REGION=us-east-1
S3_ACCESS_KEY=vmsadmin
S3_SECRET_KEY=vmsadminsecret
S3_BUCKET=vms-documents
S3_FORCE_PATH_STYLE=true

# Email — MailerSend HTTP API (transactional). Token from the MailerSend dashboard; FROM_EMAIL must
# be on a MailerSend-verified domain. Unset MAILERSEND_API_TOKEN = email disabled (sends fail/retry).
EMAIL_PROVIDER=mailersend
MAILERSEND_API_TOKEN=
MAILERSEND_FROM_EMAIL=vms@3dt.com.gh
MAILERSEND_FROM_NAME=vms

# Product/portal name shown in transactional emails (distinct from the admin-set institution name).
PLATFORM_NAME="Visitor Management System"

# SMS (SRS §10.2) — Nalo Solutions gateway. Set SMS_PROVIDER=nalo + credentials to enable;
# leave SMS_PROVIDER blank to disable SMS. NALO_SMS_SOURCE is the sender ID (must be registered
# with Nalo). NALO_SMS_ENDPOINT may point at an on-prem Nalo-compatible gateway for air-gapped sites.
SMS_PROVIDER=
NALO_SMS_USERNAME=
NALO_SMS_PASSWORD=
NALO_SMS_SOURCE=VMS
NALO_SMS_ENDPOINT=https://sms.nalosolutions.com/smsbackend/clientapi/Resl_Nalo/send-message/

# Internal chat (SRS §10.2) — Mattermost/Rocket.Chat-compatible incoming webhook (self-hosted,
# air-gap friendly). Set CHAT_WEBHOOK_URL to enable; leave blank to disable the chat channel.
CHAT_WEBHOOK_URL=
CHAT_DEFAULT_CHANNEL=
CHAT_USERNAME=VMS
# Channel/handle security incidents post to (falls back to CHAT_DEFAULT_CHANNEL), e.g. #security
SECURITY_CHAT_CHANNEL=

# On-prem AI runtime (air-gapped, OpenAI-compatible). Unset AI_LLM_URL = AI disabled.
#   Production: vLLM on a GPU box  -> AI_LLM_URL=http://localhost:8000/v1, model qwen2.5-14b-instruct-awq
#   Local dev:  Docker Model Runner -> AI_LLM_URL=http://localhost:12434/engines/v1, model ai/qwen2.5:7B
#               (enable: docker desktop enable model-runner --tcp 12434; docker model pull ai/<model>)
# Embeddings must be 1024-dim to match incident.embedding (bge-m3 / ai/mxbai-embed-large). AI_EMBED_URL
# falls back to AI_LLM_URL when blank (DMR & vLLM serve embeddings on the same endpoint, by model).
AI_LLM_URL=
AI_LLM_MODEL=qwen2.5-14b-instruct-awq
AI_LLM_API_KEY=
AI_EMBED_URL=
AI_EMBED_MODEL=bge-m3
# Vision model for ID-document extraction (B1) — served on AI_LLM_URL. dev: ai/gemma3 (DMR).
AI_VISION_MODEL=ai/gemma3
# Speech-to-text (A1 voice input) — OpenAI-compatible Whisper server (docker-compose `whisper`).
# Unset = voice input disabled. dev: http://localhost:9099/v1
AI_STT_URL=
AI_STT_MODEL=base
# Text-to-speech (A1 voice output / read-aloud) — OpenAI-compatible Piper server (docker-compose
# `tts`). Unset = read-aloud disabled. dev: http://localhost:9088/v1. Voice (one of alloy/echo/
# fable/onyx/nova/shimmer; fable is UK English, the rest US) + speaking rate are admin-configurable
# at runtime (System settings). AI_TTS_VOICE is the fallback default; voices download on first synth.
AI_TTS_URL=
AI_TTS_MODEL=tts-1
AI_TTS_VOICE=nova
# Twi/Akan read-aloud — separate OpenAI-compatible engine (BibleTTS Asante Twi via Coqui TTS,
# docker-compose `twi-tts`). Unset = Twi/Akan unavailable (read-aloud uses English). dev:
# http://localhost:9087/v1. Model + data are CC-BY-SA-4.0 (commercial use OK; ShareAlike applies).
# Pre-stage ./.data/twi-tts/asante-twi/ (config.json + model_file.pth) for an air-gapped install.
AI_TTS_AKAN_URL=
AI_TIMEOUT_MS=30000

# MCP server (A3) — read-only VMS tools for an on-prem AI assistant at POST /mcp (Bearer auth).
# Unset MCP_API_KEY = disabled. MCP_ROLE scopes the tool surface via RBAC (e.g. auditor).
MCP_API_KEY=
MCP_ROLE=security_manager

# Integrations (SRS §10.4) — all optional; unset disables the feature
# Shared secret for the external REST/OpenAPI gateway (sent as X-API-Key)
INTEGRATION_API_KEY=
# Physical access-control system webhook (POSTed on credential activate/deactivate)
ACCESS_CONTROL_WEBHOOK_URL=
# SIEM/security logging webhook (POSTed security-relevant incidents)
SIEM_WEBHOOK_URL=
# Default data-retention period in days (admin-configurable at runtime)
RETENTION_DAYS_DEFAULT=365
