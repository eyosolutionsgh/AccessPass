# ──────────────────────────────────────────────────────────────────────────────
# VMS production env — copy to deploy/.env on the server and fill in.  NEVER commit .env.
# Service hostnames (postgres/redis/minio) are the docker-compose service names.
#
# Generate secrets:
#   POSTGRES_PASSWORD / MINIO_ROOT_PASSWORD / S3_SECRET_KEY : openssl rand -hex 24
#   BETTER_AUTH_SECRET / QR_TOKEN_SECRET                    : openssl rand -base64 32
#   FIELD_ENCRYPTION_KEY                                    : openssl rand -hex 16  (= 32 chars)
# ──────────────────────────────────────────────────────────────────────────────

# ---- Internal hostnames (Caddy TLS) ----
# Web SPA host and the dedicated API host (both must resolve to this server).
VMS_DOMAIN=vms.3dt.com.gh
VMS_API_DOMAIN=api.vms.3dt.com.gh
# API origin baked into the web bundle at build time (browser calls the API host directly).
VITE_API_URL=https://api.vms.3dt.com.gh
# Web origins baked into the web bundle for staff URL guidance in /help.
VITE_INTERNAL_WEB_ORIGIN=https://vms.3dt.com.gh
VITE_LOCAL_WEB_ORIGIN=http://localhost:5173
# API origin (CORS allow-list + better-auth trusted origin) and the browser/web origin.
APP_URL=https://api.vms.3dt.com.gh
WEB_ORIGIN=https://vms.3dt.com.gh

# ---- Auth (better-auth) ----
BETTER_AUTH_SECRET=change-me-base64-32-bytes
BETTER_AUTH_URL=https://api.vms.3dt.com.gh

# ---- App secrets ----
QR_TOKEN_SECRET=change-me-base64-32-bytes
FIELD_ENCRYPTION_KEY=change-me-exactly-32-characters!!

# ---- PostgreSQL (internal) ----
POSTGRES_USER=vms
POSTGRES_PASSWORD=change-me-long-random
POSTGRES_DB=vms
DATABASE_URL=postgresql://vms:change-me-long-random@postgres:5432/vms

# ---- Redis (internal) ----
REDIS_URL=redis://redis:6379

# ---- Object storage — MinIO (internal) ----
MINIO_ROOT_USER=vmsadmin
MINIO_ROOT_PASSWORD=change-me-long-random
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=vmsadmin
S3_SECRET_KEY=change-me-long-random
S3_BUCKET=vms-documents

# ---- Email — MailerSend HTTP API ----
# Mail is sent via the MailerSend API (no SMTP). The API token comes from the MailerSend dashboard.
# MAILERSEND_FROM_EMAIL must be on a MailerSend-verified domain (3dt.com.gh is DKIM/SPF-verified).
# Don't test with @mailinator.com (MailerSend blocklists it) — verify with a real mailbox.
EMAIL_PROVIDER=mailersend
MAILERSEND_API_TOKEN=
MAILERSEND_FROM_EMAIL=vms@3dt.com.gh
MAILERSEND_FROM_NAME=vms

# Product/portal name shown in transactional emails (distinct from the admin-set institution name).
PLATFORM_NAME="Access Pass"

# ---- SMS (optional — Nalo Solutions gateway). Leave SMS_PROVIDER blank to disable. ----
SMS_PROVIDER=
NALO_SMS_USERNAME=
NALO_SMS_PASSWORD=
NALO_SMS_SOURCE=VMS

# ---- Misc ----
RETENTION_DAYS_DEFAULT=365
# Run the idempotent seed (aaodoom@gmail.com / Admin123!) on container start. Set false after
# first boot once you've changed the admin password.
SEED_ON_START=true
