# Electron kiosk configuration (set in the launching environment).
# The web check-in UI is loaded from this origin:
KIOSK_WEB_URL=http://localhost:5173

# Identify this kiosk so check-ins record the device and enforce the correct premises.
KIOSK_DEVICE_ID=reception-kiosk-1
# KIOSK_PREMISES_ID=<premises uuid>   # leave unset to accept any premises (single-site dev)

# Physical badge printer (system device name). Unset → badges render to PDF in the temp dir.
# KIOSK_PRINTER=Brother_QL_820NWB
