{
  "name": "@vms/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./router": "./src/trpc/routers/index.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts src/migrate.ts src/seed.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "seed": "tsx src/seed.ts",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@trpc/server": "^11.6.0",
    "@vms/shared": "workspace:*",
    "better-auth": "^1.6.11",
    "bullmq": "^5.34.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "ioredis": "5.10.1",
    "libphonenumber-js": "^1.13.7",
    "nanoid": "^5.1.5",
    "nodemailer": "^6.10.0",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.2.0",
    "socket.io": "^4.8.3",
    "superjson": "^1.13.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^24.7.0",
    "@types/nodemailer": "^6.4.16",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^6.0.2",
    "esbuild": "^0.25.0",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.1",
    "typescript": "5.9.3",
    "vitest": "^2.1.4"
  }
}
